{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Xzenia Attested Outcome",
  "type": "object",
  "required": ["case_id", "recorded_at", "outcome_type", "evidence_refs"],
  "properties": {
    "case_id": {"type": "string"},
    "recorded_at": {"type": "string"},
    "outcome_type": {"type": "string"},
    "outcome_value": {"type": ["number", "null"]},
    "outcome_notes": {"type": "string"},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  }
}
